@page "/"
@page "/goal-tracker"
@rendermode InteractiveServer

@using RunningGoalTracker.Components.GoalTracker
@using RunningGoalTracker.Models
@using RunningGoalTracker.Models.enums
<div class="dashboard-page @ThemeClass">
    <header class="dashboard-hero">
        <div>
            <p class="eyebrow">Strava-powered annual goal tracker</p>
            <h1>StrideIQ</h1>
            <p class="hero-subtitle">
                Track year progress, running progress, adaptive monthly targets, and Strava-synced mileage.
            </p>
        </div>
        <div class="hero-status @PaceStatusClass">
            <span>@PaceStatusText</span>
            <strong>
                @(ProgressDifference >= 0 ? "+" : "")
                @ProgressDifference.ToString("0.0")%
            </strong>
        </div>
        <div class="connection-pill">
            <span class="connection-dot"></span>
            @StravaSyncText
        </div>
        <button class="theme-toggle"
                @onclick="ToggleTheme">
            @(!IsDarkMode ? "☀️ Light Mode" : "🌙 Dark Mode")
        </button>
    </header>
    <section class="metric-grid">

        <div class="metric-card metric-card-blue">
            <span>🏃 Total Mileage</span>
            <strong>@FormatDistance(GoalService.GetTotalMiles(goal))</strong>
        </div>

        <div class="metric-card metric-card-green">
            <span>🎯 Remaining</span>
            <strong>@FormatDistance(GoalService.GetMilesRemaining(goal))</strong>
        </div>

        <div class="metric-card metric-card-purple">
            <span>📈 Completion</span>
            <strong>@GoalCompletionPercent.ToString("0.0")%</strong>
            <small>
                @GoalService.GetTotalMiles(goal).ToString("0")
                /
                @goal.GoalMiles.ToString("0")
                @UnitLabel
            </small>
        </div>

        <div class="metric-card metric-card-amber">
            <span>📅 Daily Need</span>
            <strong>@FormatDistance(GoalService.GetMilesPerDayNeeded(goal))</strong>
        </div>

        <div class="metric-card metric-card-teal">
            <span>🔮 Projected Annual</span>
            <strong>@FormatDistance(ProjectedAnnualMiles)</strong>
        </div>

        <div class="metric-card metric-card-pink">
            <span>🏁 Finish Date</span>
            <strong>@ProjectedFinishDateText</strong>
        </div>

    </section>
    <section class="forecast-card @ProjectionClass">
        <div>
            <p class="eyebrow">Pace Forecast</p>
            <h2>At your current pace, you are projected to finish with</h2>

            <strong class="forecast-number">
                @FormatDistance(ProjectedAnnualMiles)
            </strong>

            <p class="forecast-detail">
                Goal: @FormatDistance(goal.GoalMiles) · @ProjectedGoalDifferenceText
            </p>
        </div>

        <div class="forecast-date">
            <span>Projected Finish</span>
            <strong>@ProjectedFinishDateText</strong>
        </div>
    </section>
    @if (AchievementBadges.Any())
    {
        <section class="badge-row">
            @foreach (var badge in AchievementBadges)
            {
                <span class="achievement-badge">@badge</span>
            }
        </section>
    }
    <div class="forecast-gauge">
        <div class="forecast-gauge-label">
            <span>Projected Goal Achievement</span>
            <strong>@ProjectedGoalPercent.ToString("0.0")%</strong>
        </div>

        <div class="forecast-gauge-track">
            <div class="forecast-gauge-fill @ProjectionClass"
                 style="width: @ProjectedGoalWidth">
            </div>
        </div>
    </div>
    <section class="dashboard-card dashboard-card-wide">
        <GoalScenarioPanel GoalScenarios="@GoalScenarios"
                           FormatDistance="@FormatDistance" />
    </section>
    <main class="dashboard-grid">

        <section class="dashboard-card">
            <GoalSetupPanel UseKilometers="@(distanceUnit == DistanceUnit.Kilometers)"
                            UseKilometersChanged="@SetDistanceUnit"
                            DistanceUnitDisplay="@DistanceUnitDisplay"
                            GoalDistance="@DisplayedGoalDistance"
                            GoalDistanceChanged="@SetDisplayedGoalDistance"
                            RecordedDistance="@DisplayedCurrentDistance"
                            RecordedDistanceChanged="@SetDisplayedCurrentDistance"
                            ManualDistance="@DisplayedManualDistance"
                            ManualDistanceChanged="@SetDisplayedManualDistance"
                            ShowGoalError="@(goal.GoalMiles <= 0)"
                            IsLoadingStrava="@isLoadingStrava"
                            LastStravaSync="@lastStravaSync"
                            OnSyncStravaClicked="@LoadStravaMiles"
                            OnConnectStravaClicked="@ConnectToStrava"
                            OnResetClicked="@ResetValues" />
        </section>

        <section class="dashboard-card">
            <StatusSummaryPanel PaceStatusText="@PaceStatusText"
                                StatusClass="@PaceStatusClass"
                                ProgressDifference="@ProgressDifference"
                                TotalDistanceText="@FormatDistance(GoalService.GetTotalMiles(goal))"
                                RemainingDistanceText="@FormatDistance(GoalService.GetMilesRemaining(goal))"
                                ExpectedTodayText="@FormatDistance(GoalService.GetExpectedMilesToday(goal))"
                                PerDayNeededText="@FormatDistance(GoalService.GetMilesPerDayNeeded(goal))" />
        </section>


        <section class="dashboard-card">
            <ProgressComparisonPanel YearProgressPercent="@GoalService.GetYearProgressPercent()"
                                     RunningProgressPercent="@GoalService.GetRunningProgressPercent(goal)"
                                     StatusClass="@PaceStatusClass" />
        </section>

        <section class="dashboard-card dashboard-card-wide">
            <MonthlyProgressChart ProgressPoints="@GoalService.GetMonthlyProgressPoints(goal, monthlyAllocationSettings, monthlyRunTotals)"
                                  GoalMiles="@goal.GoalMiles"
                                  FormatDistance="@FormatDistance" />
        </section>
        <section class="dashboard-card dashboard-card-wide">
            <MonthlyPlanTable MonthlyAllocations="@MonthlyAllocations"
                              DistanceUnitDisplay="@DistanceUnitDisplay"
                              AllocationModeText="@AllocationModeText"
                              RemainingTotalText="@FormatDistance(GoalService.GetMilesRemaining(goal))"
                              OriginalTotalText="@FormatDistance(MonthlyAllocations.Sum(x => x.OriginalMiles))"
                              RemainingMonthlyTotalText="@FormatDistance(MonthlyAllocations.Sum(x => x.RemainingMiles))"
                              FormatDistance="@FormatDistance"
                              IsRedistributeMode="@(allocationMode == MonthlyAllocationMode.RedistributeRemaining)"
                              IsRedistributeModeChanged="@SetAllocationMode" />
        </section>
        <details class="advanced-settings">
            <summary>Advanced Settings</summary>

            <MonthlyAllocationEditor MonthlySettings="@monthlyAllocationSettings"
                                     MonthlySettingsChanged="@SetMonthlyAllocationSettings" />
        </details>
    </main>
    <footer class="dashboard-footer">
        <span>StrideIQ v1.0 </span>
        <span> Built with Blazor • .NET 9 • Strava API</span>

        <span>
            OAuth • Token Refresh • Local Persistence • Adaptive Goal Forecasting
        </span>

        <a href="https://github.com/SawdustSpike/RunningGoalTracker"
           target="_blank"
           rel="noopener noreferrer">
            View Source →
        </a>
    </footer>
</div>